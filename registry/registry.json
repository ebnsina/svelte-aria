{
	"$schema": "./schema.ts",
	"name": "svelte-aria",
	"homepage": "https://github.com/ebnsina/svelte-aria",
	"base": ["theme", "cn"],
	"items": [
		{
			"name": "theme",
			"type": "registry:style",
			"description": "Design tokens (OKLCH, re-tintable) + Tailwind preset: semantic utilities, dark-mode variant, and the global :focus-visible ring. Applied by `init`.",
			"devDependencies": ["tailwindcss", "@tailwindcss/vite"],
			"registryDependencies": ["cn"],
			"files": [
				{ "path": "src/lib/styles/theme.css", "target": "{lib}/styles/theme.css", "type": "registry:style" },
				{ "path": "src/lib/styles/tailwind.css", "target": "{lib}/styles/svelte-aria.css", "type": "registry:style" }
			],
			"css": { "imports": ["{lib}/styles/svelte-aria.css"] },
			"docs": "Import `{lib}/styles/svelte-aria.css` right after `@import 'tailwindcss';` in your app CSS. Re-theme by overriding `--sa-tint`."
		},

		{
			"name": "cn",
			"type": "registry:lib",
			"description": "Class-name merge with Tailwind conflict resolution.",
			"dependencies": ["clsx", "tailwind-merge"],
