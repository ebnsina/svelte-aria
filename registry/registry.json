{
	"$schema": "./schema.ts",
	"name": "svelte-aria",
	"homepage": "https://github.com/ebnsina/svelte-aria",
	"base": ["theme", "cn"],
	"items": [
		{
			"name": "theme",
			"type": "registry:style",
			"description": "Design tokens (OKLCH, re-tintable) + Tailwind preset: semantic utilities, dark-mode variant, and the global :focus-visible ring. Applied by `init`.",
			"devDependencies": ["tailwindcss", "@tailwindcss/vite"],
			"registryDependencies": ["cn"],
			"files": [
				{ "path": "src/lib/styles/theme.css", "target": "{lib}/styles/theme.css", "type": "registry:style" },
				{ "path": "src/lib/styles/tailwind.css", "target": "{lib}/styles/svelte-aria.css", "type": "registry:style" }
			],
			"css": { "imports": ["{lib}/styles/svelte-aria.css"] },
			"docs": "Import `{lib}/styles/svelte-aria.css` right after `@import 'tailwindcss';` in your app CSS. Re-theme by overriding `--sa-tint`."
		},

		{
			"name": "cn",
			"type": "registry:lib",
			"description": "Class-name merge with Tailwind conflict resolution.",
			"dependencies": ["clsx", "tailwind-merge"],
			"files": [{ "path": "src/lib/utils/cn.ts", "target": "{utils}/cn.ts", "type": "registry:lib" }]
		},
		{
			"name": "id",
			"type": "registry:lib",
			"description": "Stable unique-id generator for ARIA relationships.",
			"files": [{ "path": "src/lib/utils/id.ts", "target": "{lib}/id.ts", "type": "registry:lib" }]
		},
		{
			"name": "attachment-utils",
			"type": "registry:lib",
			"description": "combineAttachments + setDataAttr — compose attachments and toggle data-* state.",
			"files": [{ "path": "src/lib/utils/attachments.ts", "target": "{lib}/attachments/utils.ts", "type": "registry:lib" }]
		},
		{
			"name": "position",
			"type": "registry:lib",
			"description": "computePosition — place a floating element with viewport flip + clamp.",
			"files": [{ "path": "src/lib/utils/position.ts", "target": "{lib}/position.ts", "type": "registry:lib" }]
		},

		{
			"name": "press",
			"type": "registry:primitive",
			"description": "Unified press across mouse, touch, keyboard, and virtual (AT) activation.",
			"registryDependencies": ["attachment-utils"],
			"files": [{ "path": "src/lib/attachments/press.svelte.ts", "target": "{lib}/attachments/press.svelte.ts", "type": "registry:primitive" }]
		},
		{
			"name": "hover",
			"type": "registry:primitive",
			"description": "Mouse/pen hover that ignores touch.",
			"registryDependencies": ["attachment-utils"],
			"files": [{ "path": "src/lib/attachments/hover.svelte.ts", "target": "{lib}/attachments/hover.svelte.ts", "type": "registry:primitive" }]
		},
		{
			"name": "focus",
			"type": "registry:primitive",
			"description": "Keyboard-only focus tracking (focus-visible), via global input-modality.",
			"registryDependencies": ["attachment-utils"],
			"files": [{ "path": "src/lib/attachments/focus.svelte.ts", "target": "{lib}/attachments/focus.svelte.ts", "type": "registry:primitive" }]
		},
		{
			"name": "focus-scope",
			"type": "registry:primitive",
			"description": "Trap Tab focus in an element and restore it on teardown (modals).",
			"files": [{ "path": "src/lib/attachments/focus-scope.ts", "target": "{lib}/attachments/focus-scope.ts", "type": "registry:primitive" }]
		},
		{
			"name": "portal",
			"type": "registry:primitive",
			"description": "Move an element to document.body so overlays aren't clipped.",
			"files": [{ "path": "src/lib/attachments/portal.ts", "target": "{lib}/attachments/portal.ts", "type": "registry:primitive" }]
		},

		{
			"name": "toggle",
			"type": "registry:state",
			"description": "Controlled/uncontrolled boolean state machine (Switch/toggle buttons).",
			"files": [{ "path": "src/lib/state/toggle.svelte.ts", "target": "{lib}/state/toggle.svelte.ts", "type": "registry:state" }]
		},

		{
			"name": "accordion",
			"type": "registry:ui",
			"description": "Collapsible sections; single or multiple open.",
			"dependencies": ["@lucide/svelte"],
			"registryDependencies": ["cn", "id"],
			"files": [
				{ "path": "src/lib/components/Accordion.svelte", "target": "{ui}/accordion.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/AccordionItem.svelte", "target": "{ui}/accordion-item.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/AccordionTrigger.svelte", "target": "{ui}/accordion-trigger.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/AccordionContent.svelte", "target": "{ui}/accordion-content.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "spinner",
			"type": "registry:ui",
			"description": "Indeterminate progress circle (track + rotating arc).",
			"files": [{ "path": "src/lib/components/Spinner.svelte", "target": "{ui}/spinner.svelte", "type": "registry:ui" }]
		},
		{
			"name": "button",
			"type": "registry:ui",
			"description": "Accessible button; unified press, variants, spinner loading. Exports buttonVariants.",
			"registryDependencies": ["cn", "press", "hover", "attachment-utils", "spinner"],
			"files": [{ "path": "src/lib/components/Button.svelte", "target": "{ui}/button.svelte", "type": "registry:ui" }]
		},
		{
			"name": "checkbox",
			"type": "registry:ui",
			"description": "Native checkbox with indeterminate + animated check.",
			"dependencies": ["@lucide/svelte"],
			"registryDependencies": ["cn", "id"],
			"files": [{ "path": "src/lib/components/Checkbox.svelte", "target": "{ui}/checkbox.svelte", "type": "registry:ui" }]
		},
		{
			"name": "switch",
			"type": "registry:ui",
			"description": "On/off toggle; native switch semantics.",
			"registryDependencies": ["cn", "id"],
			"files": [{ "path": "src/lib/components/Switch.svelte", "target": "{ui}/switch.svelte", "type": "registry:ui" }]
		},
		{
			"name": "tabs",
			"type": "registry:ui",
			"description": "Tabbed interface with roving-tabindex keyboard navigation.",
			"registryDependencies": ["cn", "id"],
			"files": [
				{ "path": "src/lib/components/Tabs.svelte", "target": "{ui}/tabs.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/TabList.svelte", "target": "{ui}/tab-list.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/Tab.svelte", "target": "{ui}/tab.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/TabPanel.svelte", "target": "{ui}/tab-panel.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "text-field",
			"type": "registry:ui",
			"description": "Labelled input with description, validation, and ARIA wiring.",
			"registryDependencies": ["cn", "id"],
			"files": [{ "path": "src/lib/components/TextField.svelte", "target": "{ui}/text-field.svelte", "type": "registry:ui" }]
		},
		{
			"name": "tooltip",
			"type": "registry:ui",
			"description": "Hint on hover / keyboard focus; portaled, positioned with flip.",
			"registryDependencies": ["cn", "id", "portal", "position"],
			"files": [{ "path": "src/lib/components/Tooltip.svelte", "target": "{ui}/tooltip.svelte", "type": "registry:ui" }]
		},
		{
			"name": "popover",
			"type": "registry:ui",
			"description": "Click-triggered floating panel; portaled, positioned, dismissible.",
			"registryDependencies": ["cn", "id", "portal", "position", "button"],
			"files": [
				{ "path": "src/lib/components/Popover.svelte", "target": "{ui}/popover.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/PopoverTrigger.svelte", "target": "{ui}/popover-trigger.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/PopoverContent.svelte", "target": "{ui}/popover-content.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "menu",
			"type": "registry:ui",
			"description": "Menu button: portaled, positioned menu of actions with roving focus, typeahead, keyboard.",
			"registryDependencies": ["cn", "id", "portal", "position", "button"],
			"files": [
				{ "path": "src/lib/components/Menu.svelte", "target": "{ui}/menu.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/MenuTrigger.svelte", "target": "{ui}/menu-trigger.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/MenuContent.svelte", "target": "{ui}/menu-content.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/MenuItem.svelte", "target": "{ui}/menu-item.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/MenuSeparator.svelte", "target": "{ui}/menu-separator.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "combobox",
			"type": "registry:ui",
			"description": "Editable input + filtered listbox (list autocomplete); virtual focus, keyboard, ARIA combobox.",
			"dependencies": ["@lucide/svelte"],
			"registryDependencies": ["cn", "id", "portal", "position"],
			"files": [
				{ "path": "src/lib/components/ComboBox.svelte", "target": "{ui}/combobox.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/ComboBoxInput.svelte", "target": "{ui}/combobox-input.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/ComboBoxContent.svelte", "target": "{ui}/combobox-content.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/ComboBoxItem.svelte", "target": "{ui}/combobox-item.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "select",
			"type": "registry:ui",
			"description": "Collapsible listbox: portaled, positioned, keyboard + typeahead, single selection.",
			"dependencies": ["@lucide/svelte"],
			"registryDependencies": ["cn", "id", "portal", "position"],
			"files": [
				{ "path": "src/lib/components/Select.svelte", "target": "{ui}/select.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/SelectTrigger.svelte", "target": "{ui}/select-trigger.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/SelectContent.svelte", "target": "{ui}/select-content.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/SelectItem.svelte", "target": "{ui}/select-item.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "radio-group",
			"type": "registry:ui",
			"description": "Radio group with shared context; native keyboard navigation.",
			"registryDependencies": ["cn", "id"],
			"files": [
				{ "path": "src/lib/components/RadioGroup.svelte", "target": "{ui}/radio-group.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/Radio.svelte", "target": "{ui}/radio.svelte", "type": "registry:ui" }
			]
		},
		{
			"name": "dialog",
			"type": "registry:ui",
			"description": "Modal dialog: portal, focus trap + restore, scroll lock, dismiss.",
			"registryDependencies": ["cn", "id", "portal", "focus-scope", "button"],
			"files": [
				{ "path": "src/lib/components/Dialog.svelte", "target": "{ui}/dialog.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogTrigger.svelte", "target": "{ui}/dialog-trigger.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogContent.svelte", "target": "{ui}/dialog-content.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogHeader.svelte", "target": "{ui}/dialog-header.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogTitle.svelte", "target": "{ui}/dialog-title.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogDescription.svelte", "target": "{ui}/dialog-description.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogFooter.svelte", "target": "{ui}/dialog-footer.svelte", "type": "registry:ui" },
				{ "path": "src/lib/components/DialogClose.svelte", "target": "{ui}/dialog-close.svelte", "type": "registry:ui" }
			]
		}
	]
}
