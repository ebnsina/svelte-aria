{
	"name": "svelte-aria",
	"version": "0.0.1",
	"description": "React Aria–level behaviour, Svelte-level DX. Accessible, headless-first components for Svelte 5.",
	"author": "ebnsina",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ebnsina/svelte-aria.git"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@lucide/svelte": "^1.25.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"accessibility",
		"a11y",
		"aria",
		"headless",
		"components",
		"ui",
		"react-aria"
	],
	"dependencies": {
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0"
	}
}
